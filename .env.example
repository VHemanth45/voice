# ── Cartesia TTS ──────────────────────────────────────────
# Required: Your Cartesia API Key
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# ── Ollama LLM ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:4b

# ── Whisper STT (local faster-whisper) ────────────────────
WHISPER_MODEL=small
# Options: auto, cpu, cuda
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# ── Silero VAD ────────────────────────────────────────────
VAD_STOP_SECS=0.3
VAD_START_SECS=0.2

# ── Idle Detection ─────────────────────────────────────────
IDLE_PROMPT_SECS=15
IDLE_DISCONNECT_SECS=60

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
